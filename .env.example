# --- required: Sarvam AI (speech + LLM + TTS) ---
# Get a key from https://dashboard.sarvam.ai (free tier available)
SARVAM_API_KEY=sk_your_key_here

# --- optional: live mandi prices (data.gov.in Agmarknet) ---
# The app ships with a public sample key that works but is heavily rate-limited.
# Register free at https://data.gov.in and paste your own key for reliable prices.
# DATA_GOV_IN_API_KEY=your_data_gov_in_key

# --- optional model overrides ---
# SARVAM_CHAT_MODEL=sarvam-30b
# SARVAM_JUDGE_MODEL=sarvam-105b     # eval LLM-as-judge only
# SARVAM_TTS_SPEAKER=priya
